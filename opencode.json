{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "pxh-pm",
  "instructions": ["README.md", "runtime/README.md"],

  "compaction": {
    "auto": true,
    "strategy": "summary",
    "min_turns": 2,
    "tail_turns": 3
  },

  "tool_output": {
    "max_lines": 50,
    "max_bytes": 4096
  },

  "skills": {
    "paths": ["skills", ".opencode/skills"],
    "lazy": true
  },

  "agent": {
    "pxh-pm": { "description": "T2 Orchestrator", "mode": "primary" },
    "pxh-architect": { "description": "T3 Architect", "mode": "subagent" },
    "pxh-qa": { "description": "T3 QA", "mode": "subagent" },
    "pxh-devops": { "description": "T3 Build", "mode": "subagent" },
    "pxh-help": { "description": "T1 Interface", "mode": "primary" },
    "pxh-expert": { "description": "T3 Vibe Coder", "mode": "subagent" },
    "pxh-fix-bugs": { "description": "T3 Bug Hunter", "mode": "subagent" },
    "pxh-review-code": {
      "description": "T3 Code Reviewer",
      "mode": "subagent"
    },
    "pxh-save-history": { "description": "T4 Historian", "mode": "subagent" },
    "pxh-ui-ux": { "description": "T3 UI/UX Designer", "mode": "subagent" },
    "pxh-office": {
      "description": "Virtual Office TUI — real-time 4-tier visualization with pixel-art agents",
      "mode": "subagent"
    },
    "pxh-opencode": {
      "description": "TUI Mirror — hiển thị real-time mọi output từ TUI lên Virtual Office",
      "mode": "subagent"
    }
  },

  "command": {
    "vibe": { "template": "workflows/company.workflow.md" },
    "meeting": { "template": "workflows/meeting.workflow.md" },
    "release": { "template": "workflows/release.workflow.md" },
    "debug": { "template": "workflows/debug.workflow.md" },
    "web": { "template": "workflows/web.workflow.md" },
    "game": { "template": "workflows/game.workflow.md" },
    "ai": { "template": "workflows/ai.workflow.md" },
    "tool": { "template": "workflows/tool.workflow.md" },
    "ui-ux": { "template": "workflows/debug.workflow.md" },
    "preview": {
      "description": "Start game live preview dev server (Vite HMR + browser auto-open)",
      "template": "Load `skills/games-preview/SKILL.md`. Then run: `npm run dev` (hoặc `npx vite --open --host` nếu chưa có script)."
    },
    "office": {
      "description": "Open Virtual Office — real-time 4-tier visualization with bridge auto-detect",
      "template": "Load `skills/virtual-office/SKILL.md`. Live + Bridge: `node skills/virtual-office/templates/server.mjs` (auto-detect workspace activity). TUI: `node skills/virtual-office/templates/office.mjs`. Webview: http://localhost:2910"
    }
  }
}
